{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Gateway — debug",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nest", "start", "--debug", "--watch"],
      "cwd": "${workspaceFolder}/gateway",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "sourceMaps": true,
      "restart": true,
      "env": {
        "NODE_ENV": "development"
      },
      "envFile": "${workspaceFolder}/gateway/.env",
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/gateway/node_modules/**"
      ]
    },
    {
      "name": "Auth Service — debug",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nest", "start", "--debug", "--watch"],
      "cwd": "${workspaceFolder}/auth-service",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "sourceMaps": true,
      "restart": true,
      "env": {
        "NODE_ENV": "development"
      },
      "envFile": "${workspaceFolder}/auth-service/.env",
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/auth-service/node_modules/**"
      ]
    },
    {
      "name": "Chat Service — debug",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nest", "start", "--debug", "--watch"],
      "cwd": "${workspaceFolder}/chat-service",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "sourceMaps": true,
      "restart": true,
      "env": {
        "NODE_ENV": "development"
      },
      "envFile": "${workspaceFolder}/chat-service/.env",
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/chat-service/node_modules/**"
      ]
    }
  ],
  "compounds": [
    {
      "name": "All Services — debug",
      "configurations": [
        "Auth Service — debug",
        "Chat Service — debug"
      ],
      "stopAll": true,
    }
  ]
}
