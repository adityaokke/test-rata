# Chat Service — environment variables
# Copy to .env

# Server
NODE_ENV=development
PORT=3002
FRONTEND_URL=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/chat_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — must match auth-service exactly
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=7d

# Auth service (for inter-service token validation if needed)
AUTH_SERVICE_URL=http://localhost:3001/graphql
AUTH_SERVICE_BASE_URL=http://localhost:3001