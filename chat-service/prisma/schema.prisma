generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ── Chat Rooms ─────────────────────────────────────────────────────────────
// A room represents a customer support conversation.
// Multiple agents can join the same room (multi-agent per customer).

model ChatRoom {
  id         String   @id @default(uuid())
  customerId String // the customer this room belongs to
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  participants RoomParticipant[]
  messages     Message[]

  // Fast lookup: all rooms for a customer
  @@index([customerId])
  @@map("chat_rooms")
}

// ── Room Participants ──────────────────────────────────────────────────────
// Tracks which users are in a room and their role.
// A customer has exactly one participant row per room.
// Agents/supervisors can be added at any time.

model RoomParticipant {
  id       String          @id @default(uuid())
  roomId   String
  userId   String
  role     ParticipantRole @default(AGENT)
  joinedAt DateTime        @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  // A user can only be in a room once
  @@unique([roomId, userId])
  // Fast lookup: all rooms a user participates in
  @@index([userId])
  @@map("room_participants")
}

// ── Messages ───────────────────────────────────────────────────────────────
// Messages are NEVER inserted directly by the API.
// Flow: API → BullMQ queue → worker → this table.

model Message {
  id             String          @id @default(uuid())
  roomId         String
  senderId       String
  content        String?
  attachmentUrl  String?
  attachmentType AttachmentType?
  sequenceNumber Int
  idempotencyKey String
  status         MessageStatus   @default(PENDING)
  createdAt      DateTime        @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, idempotencyKey])
  @@index([roomId, sequenceNumber])
  @@index([roomId, createdAt])
  @@map("messages")
}

enum ParticipantRole {
  CUSTOMER
  AGENT
}

enum AttachmentType {
  IMAGE
  VIDEO
  FILE
}

enum MessageStatus {
  PENDING
  DELIVERED
  FAILED
}
