// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ── Chat Rooms ─────────────────────────────────────────────────────────────
// A room represents a 1-on-1 conversation between two users (DM style).
// participantA / participantB are always stored in sorted order (a < b)
// so we can enforce a unique constraint and prevent duplicate rooms.

model ChatRoom {
  id           String    @id @default(uuid())
  participantA String    // user id — always the lexicographically smaller id
  participantB String    // user id — always the lexicographically larger id
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  messages     Message[]

  // Prevent two users from having more than one room
  @@unique([participantA, participantB])

  // Fast lookup: "give me all rooms this user is in"
  @@index([participantA])
  @@index([participantB])

  @@map("chat_rooms")
}

// ── Messages ───────────────────────────────────────────────────────────────
// Messages are NEVER inserted directly by the API.
// Flow: API → BullMQ queue → worker → this table.

model Message {
  id              String    @id @default(uuid())
  roomId          String
  senderId        String
  content         String?   // nullable when message is attachment-only
  attachmentUrl   String?
  attachmentType  AttachmentType?
  sequenceNumber  Int       // monotonically increasing per room, assigned at publish time
  idempotencyKey  String    // client-generated UUID to prevent duplicate inserts
  status          MessageStatus @default(PENDING)
  createdAt       DateTime  @default(now())

  room  ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)

  // Primary query pattern: fetch messages for a room ordered by sequence
  @@index([roomId, sequenceNumber])

  // Secondary: cursor-based pagination by time
  @@index([roomId, createdAt])

  // Idempotency: same client key in same room = duplicate, reject it
  @@unique([roomId, idempotencyKey])

  @@map("messages")
}

enum AttachmentType {
  IMAGE
  VIDEO
  FILE
}

enum MessageStatus {
  PENDING     // published to queue, not yet persisted
  DELIVERED   // persisted to DB
  FAILED      // moved to DLQ after max retries
}
